:root{--red:#c41e3a;--red-d:#a01830;--bg:#f0f2f5;--card:#fff;--text:#1c1e21;--muted:#606770;--border:#dddfe2;--shadow:0 2px 4px rgba(0,0,0,.1),0 8px 16px rgba(0,0,0,.1)}
*{box-sizing:border-box;margin:0;padding:0;font-family:'Poppins',sans-serif}
body{background:var(--bg);color:var(--text);min-height:100vh;display:flex;justify-content:center;padding:20px;transition:.3s}
body.dark{--bg:#121212;--card:#242526;--text:#f5f6f7;--muted:#b0b3b8;--border:#3a3b3c;--shadow:0 4px 12px rgba(0,0,0,.4)}
.wrap{width:100%;max-width:720px}
.brand{text-align:center;margin-bottom:20px}
.brand img{width:64px;height:64px;border-radius:50%;border:3px solid #fff;box-shadow:var(--shadow);margin-bottom:8px}
body.dark.brand img{border-color:var(--card)}
.brand h1{color:var(--red);font-size:28px;font-weight:700}
.brand p{color:var(--muted);font-size:13px;font-weight:500}
.card{background:var(--card);border-radius:12px;box-shadow:var(--shadow);padding:22px}
.card-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;border-bottom:1px solid var(--border);padding-bottom:12px}
.card-head h2{font-size:18px}
.actions{display:flex;gap:12px}
.actions a,.actions button{background:none;border:none;color:var(--red);font-weight:600;font-size:13px;cursor:pointer;text-decoration:none}
input,textarea{width:100%;padding:14px;border:1px solid var(--border);border-radius:8px;background:transparent;color:var(--text);font-size:15px;margin-bottom:12px;outline:none;transition:.2s}
input:focus,textarea:focus{border-color:var(--red);box-shadow:0 0 0 3px rgba(196,30,58,.15)}
textarea{resize:vertical;min-height:180px;line-height:1.6}
.uploader{display:flex;align-items:center;gap:10px;margin:8px 0 16px;font-size:14px;color:var(--muted)}
.uploader label{background:var(--bg);padding:8px 14px;border-radius:6px;cursor:pointer;font-weight:500;border:1px solid var(--border)}
body.dark.uploader label{background:#3a3b3c}
#submitBtn{width:100%;padding:14px;background:var(--red);color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:600;cursor:pointer;transition:.2s}
#submitBtn:hover{background:var(--red-d)}#submitBtn:disabled{opacity:.6}
#status{text-align:center;margin-top:12px;font-size:13px;min-height:18px}
#status.ok{color:#2e7d32}#status.err{color:var(--red)}
.dark-toggle{position:fixed;top:16px;right:16px;width:40px;height:40px;border-radius:50%;border:2px solid var(--border);background:var(--card);cursor:pointer;font-size:18px;box-shadow:var(--shadow)}
